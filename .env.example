# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Site URL ─────────────────────────────────────────────────────────────────
# Used for absolute links in emails and redirects
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Resend (Email) ───────────────────────────────────────────────────────────
# Get your key at: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# The verified sender address (must match a domain you verified in Resend)
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ─── PayPal ──────────────────────────────────────────────────────────────────
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# NGN to USD exchange rate used when a Nigerian customer pays via PayPal
NGN_RATE=1650

# ─── Paystack ────────────────────────────────────────────────────────────────
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_MERCHANT_EMAIL=

# ─── CAPTCHA ─────────────────────────────────────────────────────────────────
# REQUIRED in all environments. Generate with: openssl rand -hex 32
# Must be at least 32 characters — the app will throw on startup if not set.
CAPTCHA_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# ─── Internal API Security ────────────────────────────────────────────────────
# REQUIRED in all environments. Shared secret for server-to-server calls
# (payment routes → email route). The email endpoint is disabled if not set.
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# ─── Upstash Redis ────────────────────────────────────────────────────────────
# REQUIRED for production rate limiting and captcha replay protection.
# Create a free Redis database at: https://console.upstash.com
# Without these, rate limiting and captcha nonces are disabled (insecure in prod).
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token
