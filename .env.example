# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Site URL ─────────────────────────────────────────────────────────────────
# Used for absolute links in emails and redirects
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Resend (Email) ───────────────────────────────────────────────────────────
# Get your key at: https://resend.com/api-keys
# Also store resend_api_key in site_settings table for admin-configurable override
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# The verified sender address for outgoing emails (must match a domain you verified in Resend)
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ─── PayPal ──────────────────────────────────────────────────────────────────
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# ─── Paystack ────────────────────────────────────────────────────────────────
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_MERCHANT_EMAIL=

# ─── CAPTCHA ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Must be at least 32 characters in production
CAPTCHA_SECRET=replace-with-a-long-random-secret-at-least-32-chars
